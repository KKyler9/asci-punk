[gd_scene load_steps=2 format=3 uid="uid://actnew"]

[ext_resource type="Script" path="res://scripts/activities.gd" id="1"]

[node name="Activities" type="Control"]
script = ExtResource("1")

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2
[node name="Status" type="Label" parent="MarginContainer/VBoxContainer"]
[node name="Timer" type="Label" parent="MarginContainer/VBoxContainer"]
[node name="Buttons" type="HBoxContainer" parent="MarginContainer/VBoxContainer"]
[node name="Scavenge" type="Button" parent="MarginContainer/VBoxContainer/Buttons"]
text = "Scavenging Run"
[node name="Recovery" type="Button" parent="MarginContainer/VBoxContainer/Buttons"]
text = "Recovery / Maintenance"
[node name="Collect" type="Button" parent="MarginContainer/VBoxContainer/Buttons"]
text = "Collect"
[node name="Back" type="Button" parent="MarginContainer/VBoxContainer/Buttons"]
text = "Back"

[connection signal="pressed" from="MarginContainer/VBoxContainer/Buttons/Scavenge" to="." method="_on_scavenge_pressed"]
[connection signal="pressed" from="MarginContainer/VBoxContainer/Buttons/Recovery" to="." method="_on_recovery_pressed"]
[connection signal="pressed" from="MarginContainer/VBoxContainer/Buttons/Collect" to="." method="_on_collect_pressed"]
[connection signal="pressed" from="MarginContainer/VBoxContainer/Buttons/Back" to="." method="_on_back_pressed"]
