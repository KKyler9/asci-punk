[gd_scene load_steps=2 format=3 uid="uid://gearnew"]

[ext_resource type="Script" path="res://scripts/gear.gd" id="1"]

[node name="Gear" type="Control"]
script = ExtResource("1")

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2

[node name="HBoxContainer" type="HBoxContainer" parent="MarginContainer/VBoxContainer"]

[node name="GearList" type="ItemList" parent="MarginContainer/VBoxContainer/HBoxContainer"]
custom_minimum_size = Vector2(350, 320)

[node name="ImplantList" type="ItemList" parent="MarginContainer/VBoxContainer/HBoxContainer"]
custom_minimum_size = Vector2(350, 320)

[node name="Equipped" type="Label" parent="MarginContainer/VBoxContainer"]

[node name="Buttons" type="HBoxContainer" parent="MarginContainer/VBoxContainer"]
[node name="EquipGear" type="Button" parent="MarginContainer/VBoxContainer/Buttons"]
text = "Equip Selected Gear"
[node name="InstallImplant" type="Button" parent="MarginContainer/VBoxContainer/Buttons"]
text = "Install Selected Implant"
[node name="Back" type="Button" parent="MarginContainer/VBoxContainer/Buttons"]
text = "Back"

[connection signal="pressed" from="MarginContainer/VBoxContainer/Buttons/EquipGear" to="." method="_on_equip_gear_pressed"]
[connection signal="pressed" from="MarginContainer/VBoxContainer/Buttons/InstallImplant" to="." method="_on_install_implant_pressed"]
[connection signal="pressed" from="MarginContainer/VBoxContainer/Buttons/Back" to="." method="_on_back_pressed"]
